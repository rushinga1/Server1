# ======================================================
# AGRUNI OTP Server — Environment Variables (Email OTP)
# ======================================================

# SMTP Configuration (e.g., Gmail, SendGrid, Amazon SES)
# For Gmail, use an App Password: https://myaccount.google.com/apppasswords
# Email provider mode: gmail_api (no custom domain required), resend, smtp, or auto
EMAIL_PROVIDER=gmail_api

# Gmail API (recommended free option when no custom domain is available)
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
GMAIL_SENDER=yourgmail@gmail.com

# Put your Gmail address here
SMTP_USER=mugishaguevara12@gmail.com
SMTP_FROM=mugishaguevara12@gmail.com
SMTP_HOST=smtp.gmail.com

SMTP_PORT=587
SMTP_SECURE=false

# Put the 16-letter password here (remove the spaces!)
SMTP_PASS=gjfnlnhjatiqweka

PORT=3001
CLIENT_URL=http://localhost:5173

# Resend fallback (used only if SMTP_* is not set)
# In production, set RESEND_FROM to a verified domain sender like:
# RESEND_FROM="Agruni Portal <noreply@yourdomain.com>"
RESEND_API_KEY=
RESEND_FROM="Agruni Portal <onboarding@resend.dev>"
